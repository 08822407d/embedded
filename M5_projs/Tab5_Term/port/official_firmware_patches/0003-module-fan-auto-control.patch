+/*
+ * SPDX-FileCopyrightText: 2026 Tab5 terminal port contributors
+ *
+ * SPDX-License-Identifier: MIT
+ */
+#pragma once
+
+#include <cstddef>
+#include <cstdint>
+
+namespace module_fan {
+
+constexpr size_t kPolicyLevelCount = 4;
+constexpr uint32_t kDefaultControlIntervalMs = 5000;
+
+struct PolicyLevel {
+    int16_t enter_deci_celsius = 0;
+    int16_t exit_deci_celsius = 0;
+    uint8_t duty_percent = 0;
+};
+
+struct PolicyConfig {
+    uint32_t interval_ms = kDefaultControlIntervalMs;
+    uint8_t sensor_failsafe_duty_percent = 50;
+    PolicyLevel levels[kPolicyLevelCount] = {};
+};
+
+struct PolicyDemand {
+    uint8_t cooling_level = 0;
+    uint8_t duty_percent = 0;
+};
+
+PolicyConfig defaultPolicyConfig();
+bool validatePolicyConfig(const PolicyConfig& config);
+bool policyConfigsEqual(const PolicyConfig& left, const PolicyConfig& right);
+
+class AutomaticPolicy {
+public:
+    AutomaticPolicy();
+
+    bool setConfig(const PolicyConfig& config);
+    void reset();
+    PolicyDemand update(bool temperature_valid, float temperature_celsius);
+
+private:
+    PolicyConfig _config;
+    uint8_t _cooling_level = 0;
+};
+
+} // namespace module_fan
diff --git a/platforms/tab5/main/hal/components/module_fan/module_fan_service.cpp b/platforms/tab5/main/hal/components/module_fan/module_fan_service.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..123d6c343313bd45800e78c6653450add1c74634
--- /dev/null
+++ b/platforms/tab5/main/hal/components/module_fan/module_fan_service.cpp
@@ -0,0 +1,329 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Tab5 terminal port contributors
+ *
+ * SPDX-License-Identifier: MIT
+ */
+#include "module_fan_service.h"
+
+#include <atomic>
+#include <mutex>
+
+#include <esp_timer.h>
+#include <freertos/FreeRTOS.h>
+#include <freertos/task.h>
+#include <nvs.h>
+
+#include "../cpu_temperature.h"
+#include "module_fan_config_store.h"
+#include "module_fan_device.h"
+
+namespace module_fan {
+namespace {
+
+constexpr uint8_t kMissedPollsToDetach = 3;
+constexpr uint8_t kInvalidDutyPercent = 0xFF;
+
+Device g_device;
+std::atomic_bool g_started{false};
+std::mutex g_snapshot_mutex;
+Snapshot g_snapshot;
+std::mutex g_policy_mutex;
+PolicyState g_policy_state;
+PolicyConfig g_persisted_policy;
+bool g_has_persisted_policy = false;
+TaskHandle_t g_task_handle = nullptr;
+
+void advancePolicyRevisionLocked()
+{
+    ++g_policy_state.revision;
+    if (g_policy_state.revision == 0) {
+        g_policy_state.revision = 1;
+    }
+}
+
+TaskHandle_t replaceActivePolicyLocked(const PolicyConfig& config, PolicySource source, bool dirty)
+{
+    const bool changed = !policyConfigsEqual(g_policy_state.config, config);
+    g_policy_state.config = config;
+    g_policy_state.source = source;
+    g_policy_state.dirty = dirty;
+    if (changed) {
+        advancePolicyRevisionLocked();
+        return g_task_handle;
+    }
+    return nullptr;
+}
+
+void notifyPolicyChanged(TaskHandle_t task_handle)
+{
+    if (task_handle != nullptr) {
+        xTaskNotifyGive(task_handle);
+    }
+}
+
+void selectRuntimePolicyStateLocked(const PolicyConfig& config, PolicySource* source, bool* dirty)
+{
+    if (g_has_persisted_policy && policyConfigsEqual(config, g_persisted_policy)) {
+        *source = PolicySource::PersistedNvs;
+        *dirty = false;
+        return;
+    }
+
+    if (!g_has_persisted_policy && policyConfigsEqual(config, defaultPolicyConfig())) {
+        *source = PolicySource::CompiledDefaults;
+        *dirty = false;
+        return;
+    }
+
+    *source = PolicySource::Runtime;
+    *dirty = true;
+}
+
+void publishSnapshot(Snapshot snapshot)
+{
+    std::lock_guard<std::mutex> lock(g_snapshot_mutex);
+    snapshot.sequence = g_snapshot.sequence + 1;
+    g_snapshot = snapshot;
+}
+
+void taskEntry(void*)
+{
+    bool attached = false;
+    uint8_t firmware_version = 0;
+    uint8_t last_applied_duty_percent = kInvalidDutyPercent;
+    uint8_t missed_polls = 0;
+    uint16_t last_rpm = 0;
+    bool reconfigure_after_error = false;
+    uint32_t active_policy_revision = 0;
+    AutomaticPolicy policy;
+
+    while (true) {
+        PolicyState policy_state;
+        getPolicyState(&policy_state);
+        ulTaskNotifyTake(pdTRUE, pdMS_TO_TICKS(policy_state.config.interval_ms));
+        getPolicyState(&policy_state);
+
+        if (policy_state.revision != active_policy_revision) {
+            policy.setConfig(policy_state.config);
+            active_policy_revision = policy_state.revision;
+        }
+
+        Snapshot snapshot;
+        snapshot.uptime_ms = static_cast<uint64_t>(esp_timer_get_time()) / 1000;
+        snapshot.temperature_valid = cpu_temperature::read(&snapshot.temperature_celsius);
+        const PolicyDemand demand = policy.update(snapshot.temperature_valid, snapshot.temperature_celsius);
+        snapshot.cooling_level = demand.cooling_level;
+        snapshot.target_duty_percent = demand.duty_percent;
+        snapshot.policy_revision = active_policy_revision;
+
+        if (!attached && g_device.probe() == ESP_OK) {
+            uint8_t detected_firmware_version = 0;
+            if (g_device.connect() == ESP_OK && g_device.readIdentity(&detected_firmware_version) == ESP_OK
+                && g_device.configurePwm24KHz() == ESP_OK) {
+                attached = true;
+                firmware_version = detected_firmware_version;
+                last_applied_duty_percent = kInvalidDutyPercent;
+                missed_polls = 0;
+                reconfigure_after_error = false;
+            } else {
+                g_device.disconnect();
+            }
+        }
+
+        bool communication_ok = false;
+        if (attached) {
+            esp_err_t result = ESP_OK;
+            if (reconfigure_after_error) {
+                result = g_device.configurePwm24KHz();
+            }
+            if (result == ESP_OK
+                && (reconfigure_after_error || snapshot.target_duty_percent != last_applied_duty_percent)) {
+                result = g_device.applyDutyPercent(snapshot.target_duty_percent);
+                if (result == ESP_OK) {
+                    last_applied_duty_percent = snapshot.target_duty_percent;
+                }
+            }
+
+            uint16_t rpm = 0;
+            if (result == ESP_OK) {
+                result = g_device.readRpm(&rpm);
+            }
+
+            communication_ok = result == ESP_OK;
+            if (communication_ok) {
+                last_rpm = rpm;
+                missed_polls = 0;
+                reconfigure_after_error = false;
+            } else {
+                reconfigure_after_error = true;
+                if (missed_polls < 0xFF) {
+                    ++missed_polls;
+                }
+                if (missed_polls >= kMissedPollsToDetach) {
+                    attached = false;
+                    firmware_version = 0;
+                    last_applied_duty_percent = kInvalidDutyPercent;
+                    last_rpm = 0;
+                    reconfigure_after_error = false;
+                    g_device.disconnect();
+                }
+            }
+        }
+
+        snapshot.attached = attached;
+        snapshot.communication_ok = communication_ok;
+        snapshot.applied_duty_percent =
+            last_applied_duty_percent == kInvalidDutyPercent ? 0 : last_applied_duty_percent;
+        snapshot.rpm = last_rpm;
+        snapshot.firmware_version = firmware_version;
+        snapshot.missed_polls = missed_polls;
+        publishSnapshot(snapshot);
+    }
+}
+
+} // namespace
+
+esp_err_t start(i2c_master_bus_handle_t bus_handle)
+{
+    bool expected = false;
+    if (!g_started.compare_exchange_strong(expected, true)) {
+        return ESP_OK;
+    }
+
+    const esp_err_t begin_result = g_device.begin(bus_handle);
+    if (begin_result != ESP_OK) {
+        g_started = false;
+        return begin_result;
+    }
+
+    loadPolicyConfig();
+
+    TaskHandle_t task_handle = nullptr;
+    const BaseType_t task_result = xTaskCreate(taskEntry, "module_fan_auto", 4096, nullptr, 1, &task_handle);
+    if (task_result != pdPASS) {
+        g_started = false;
+        return ESP_ERR_NO_MEM;
+    }
+
+    {
+        std::lock_guard<std::mutex> lock(g_policy_mutex);
+        g_task_handle = task_handle;
+    }
+
+    return ESP_OK;
+}
+
+bool getSnapshot(Snapshot* snapshot)
+{
+    if (snapshot == nullptr) {
+        return false;
+    }
+
+    std::lock_guard<std::mutex> lock(g_snapshot_mutex);
+    *snapshot = g_snapshot;
+    return snapshot->sequence != 0;
+}
+
+bool getPolicyState(PolicyState* state)
+{
+    if (state == nullptr) {
+        return false;
+    }
+
+    std::lock_guard<std::mutex> lock(g_policy_mutex);
+    *state = g_policy_state;
+    return true;
+}
+
+esp_err_t setPolicyConfig(const PolicyConfig& config)
+{
+    if (!validatePolicyConfig(config)) {
+        return ESP_ERR_INVALID_ARG;
+    }
+
+    TaskHandle_t task_handle = nullptr;
+    {
+        std::lock_guard<std::mutex> lock(g_policy_mutex);
+        PolicySource source = PolicySource::Runtime;
+        bool dirty = true;
+        selectRuntimePolicyStateLocked(config, &source, &dirty);
+        task_handle = replaceActivePolicyLocked(config, source, dirty);
+    }
+    notifyPolicyChanged(task_handle);
+    return ESP_OK;
+}
+
+esp_err_t savePolicyConfig()
+{
+    PolicyConfig config;
+    {
+        std::lock_guard<std::mutex> lock(g_policy_mutex);
+        config = g_policy_state.config;
+    }
+
+    const esp_err_t result = config_store::save(config);
+    if (result != ESP_OK) {
+        return result;
+    }
+
+    std::lock_guard<std::mutex> lock(g_policy_mutex);
+    g_persisted_policy = config;
+    g_has_persisted_policy = true;
+    if (policyConfigsEqual(g_policy_state.config, config)) {
+        g_policy_state.source = PolicySource::PersistedNvs;
+        g_policy_state.dirty = false;
+    } else {
+        g_policy_state.source = PolicySource::Runtime;
+        g_policy_state.dirty = true;
+    }
+    return ESP_OK;
+}
+
+esp_err_t loadPolicyConfig()
+{
+    PolicyConfig config;
+    const esp_err_t result = config_store::load(&config);
+    const bool use_defaults = result == ESP_ERR_NVS_NOT_FOUND || result == ESP_ERR_INVALID_RESPONSE;
+    if (result != ESP_OK && !use_defaults) {
+        return result;
+    }
+
+    if (use_defaults) {
+        config = defaultPolicyConfig();
+    }
+
+    TaskHandle_t task_handle = nullptr;
+    {
+        std::lock_guard<std::mutex> lock(g_policy_mutex);
+        g_has_persisted_policy = !use_defaults;
+        if (g_has_persisted_policy) {
+            g_persisted_policy = config;
+        }
+        task_handle = replaceActivePolicyLocked(config,
+                                                use_defaults ? PolicySource::CompiledDefaults
+                                                             : PolicySource::PersistedNvs,
+                                                false);
+    }
+    notifyPolicyChanged(task_handle);
+    return ESP_OK;
+}
+
+void restoreDefaultPolicy()
+{
+    setPolicyConfig(defaultPolicyConfig());
+}
+
+const char* policySourceName(PolicySource source)
+{
+    switch (source) {
+        case PolicySource::CompiledDefaults:
+            return "defaults";
+        case PolicySource::PersistedNvs:
+            return "nvs";
+        case PolicySource::Runtime:
+            return "runtime";
+    }
+    return "unknown";
+}
+
+} // namespace module_fan
