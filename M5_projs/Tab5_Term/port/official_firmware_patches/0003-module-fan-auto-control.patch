diff --git a/app/debug/module_fan_policy_commands.cpp b/app/debug/module_fan_policy_commands.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..ee0fc3ce6452c2bb6b8f5a48e49383ac3e389801
--- /dev/null
+++ b/app/debug/module_fan_policy_commands.cpp
@@ -0,0 +1,301 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Tab5 terminal port contributors
+ *
+ * SPDX-License-Identifier: MIT
+ */
+#include "module_fan_policy_commands.h"
+
+#include <cstdint>
+#include <cstdio>
+#include <cstring>
+#include <limits>
+
+#include <esp_err.h>
+#include <hal/components/module_fan/module_fan_service.h>
+
+namespace debug {
+namespace module_fan_policy_commands {
+namespace {
+
+constexpr char kSetCurvePrefix[] = "module-fan-policy=set,";
+constexpr char kSetIntervalPrefix[] = "module-fan-policy-interval=set,";
+constexpr char kSetFailsafePrefix[] = "module-fan-policy-failsafe=set,";
+
+bool isDigit(char value)
+{
+    return value >= '0' && value <= '9';
+}
+
+bool parseUnsigned(const char** cursor, uint32_t* value)
+{
+    if (cursor == nullptr || *cursor == nullptr || value == nullptr || !isDigit(**cursor)) {
+        return false;
+    }
+
+    const char* current = *cursor;
+    uint32_t parsed = 0;
+    while (isDigit(*current)) {
+        const uint32_t digit = static_cast<uint32_t>(*current - '0');
+        if (parsed > (std::numeric_limits<uint32_t>::max() - digit) / 10) {
+            return false;
+        }
+        parsed = parsed * 10 + digit;
+        ++current;
+    }
+
+    *cursor = current;
+    *value = parsed;
+    return true;
+}
+
+bool parseDeciCelsius(const char** cursor, int16_t* value)
+{
+    uint32_t whole = 0;
+    if (!parseUnsigned(cursor, &whole)) {
+        return false;
+    }
+
+    uint32_t tenths = 0;
+    if (**cursor == '.') {
+        ++(*cursor);
+        if (!isDigit(**cursor)) {
+            return false;
+        }
+        tenths = static_cast<uint32_t>(**cursor - '0');
+        ++(*cursor);
+        if (isDigit(**cursor)) {
+            return false;
+        }
+    }
+
+    if (whole > static_cast<uint32_t>(std::numeric_limits<int16_t>::max()) / 10) {
+        return false;
+    }
+    const uint32_t deci_celsius = whole * 10 + tenths;
+    if (deci_celsius > static_cast<uint32_t>(std::numeric_limits<int16_t>::max())) {
+        return false;
+    }
+
+    *value = static_cast<int16_t>(deci_celsius);
+    return true;
+}
+
+bool consume(const char** cursor, char expected)
+{
+    if (**cursor != expected) {
+        return false;
+    }
+    ++(*cursor);
+    return true;
+}
+
+bool parseCurve(const char* text, module_fan::PolicyConfig* config)
+{
+    if (text == nullptr || config == nullptr) {
+        return false;
+    }
+
+    module_fan::PolicyConfig candidate = *config;
+    const char* cursor = text;
+    for (size_t index = 0; index < module_fan::kPolicyLevelCount; ++index) {
+        int16_t enter_deci_celsius = 0;
+        int16_t exit_deci_celsius = 0;
+        uint32_t duty_percent = 0;
+        if (!parseDeciCelsius(&cursor, &enter_deci_celsius) || !consume(&cursor, ',')
+            || !parseDeciCelsius(&cursor, &exit_deci_celsius) || !consume(&cursor, ',')
+            || !parseUnsigned(&cursor, &duty_percent) || duty_percent > UINT8_MAX) {
+            return false;
+        }
+
+        candidate.levels[index] = {
+            enter_deci_celsius,
+            exit_deci_celsius,
+            static_cast<uint8_t>(duty_percent),
+        };
+
+        if (index + 1 < module_fan::kPolicyLevelCount) {
+            if (!consume(&cursor, '/')) {
+                return false;
+            }
+        } else if (*cursor != '\0') {
+            return false;
+        }
+    }
+
+    if (!module_fan::validatePolicyConfig(candidate)) {
+        return false;
+    }
+    *config = candidate;
+    return true;
+}
+
+bool parseExactUnsigned(const char* text, uint32_t* value)
+{
+    const char* cursor = text;
+    return parseUnsigned(&cursor, value) && *cursor == '\0';
+}
+
+void writeError(LineWriter writer, const char* action, const char* reason)
+{
+    if (writer == nullptr) {
+        return;
+    }
+
+    char line[128];
+    snprintf(line, sizeof(line), "TAB5FAN POLICY ERR action=%s reason=%s", action, reason);
+    writer(line);
+}
+
+void writeEspError(LineWriter writer, const char* action, esp_err_t error)
+{
+    writeError(writer, action, esp_err_to_name(error));
+}
+
+void writePolicyState(LineWriter writer, const char* action)
+{
+    if (writer == nullptr) {
+        return;
+    }
+
+    module_fan::PolicyState state;
+    if (!module_fan::getPolicyState(&state)) {
+        writeError(writer, action, "state-unavailable");
+        return;
+    }
+
+    const auto& levels = state.config.levels;
+    char line[320];
+    snprintf(line,
+             sizeof(line),
+             "TAB5FAN POLICY action=%s source=%s dirty=%u revision=%lu interval_ms=%lu failsafe_pct=%u "
+             "curve=%d.%u,%d.%u,%u/%d.%u,%d.%u,%u/%d.%u,%d.%u,%u/%d.%u,%d.%u,%u",
+             action,
+             module_fan::policySourceName(state.source),
+             state.dirty ? 1u : 0u,
+             static_cast<unsigned long>(state.revision),
+             static_cast<unsigned long>(state.config.interval_ms),
+             static_cast<unsigned>(state.config.sensor_failsafe_duty_percent),
+             levels[0].enter_deci_celsius / 10,
+             static_cast<unsigned>(levels[0].enter_deci_celsius % 10),
+             levels[0].exit_deci_celsius / 10,
+             static_cast<unsigned>(levels[0].exit_deci_celsius % 10),
+             static_cast<unsigned>(levels[0].duty_percent),
+             levels[1].enter_deci_celsius / 10,
+             static_cast<unsigned>(levels[1].enter_deci_celsius % 10),
+             levels[1].exit_deci_celsius / 10,
+             static_cast<unsigned>(levels[1].exit_deci_celsius % 10),
+             static_cast<unsigned>(levels[1].duty_percent),
+             levels[2].enter_deci_celsius / 10,
+             static_cast<unsigned>(levels[2].enter_deci_celsius % 10),
+             levels[2].exit_deci_celsius / 10,
+             static_cast<unsigned>(levels[2].exit_deci_celsius % 10),
+             static_cast<unsigned>(levels[2].duty_percent),
+             levels[3].enter_deci_celsius / 10,
+             static_cast<unsigned>(levels[3].enter_deci_celsius % 10),
+             levels[3].exit_deci_celsius / 10,
+             static_cast<unsigned>(levels[3].exit_deci_celsius % 10),
+             static_cast<unsigned>(levels[3].duty_percent));
+    writer(line);
+}
+
+} // namespace
+
+bool handleCommand(const char* command, LineWriter writer)
+{
+    if (command == nullptr) {
+        return false;
+    }
+
+    if (strcmp(command, "module-fan-policy?") == 0) {
+        writePolicyState(writer, "query");
+        return true;
+    }
+
+    if (strncmp(command, kSetCurvePrefix, sizeof(kSetCurvePrefix) - 1) == 0) {
+        module_fan::PolicyState state;
+        module_fan::getPolicyState(&state);
+        module_fan::PolicyConfig candidate = state.config;
+        if (!parseCurve(command + sizeof(kSetCurvePrefix) - 1, &candidate)) {
+            writeError(writer, "set", "invalid-curve");
+            return true;
+        }
+
+        const esp_err_t result = module_fan::setPolicyConfig(candidate);
+        if (result != ESP_OK) {
+            writeEspError(writer, "set", result);
+        } else {
+            writePolicyState(writer, "set");
+        }
+        return true;
+    }
+
+    if (strncmp(command, kSetIntervalPrefix, sizeof(kSetIntervalPrefix) - 1) == 0) {
+        uint32_t interval_ms = 0;
+        if (!parseExactUnsigned(command + sizeof(kSetIntervalPrefix) - 1, &interval_ms)) {
+            writeError(writer, "set-interval", "invalid-value");
+            return true;
+        }
+
+        module_fan::PolicyState state;
+        module_fan::getPolicyState(&state);
+        state.config.interval_ms = interval_ms;
+        const esp_err_t result = module_fan::setPolicyConfig(state.config);
+        if (result != ESP_OK) {
+            writeEspError(writer, "set-interval", result);
+        } else {
+            writePolicyState(writer, "set-interval");
+        }
+        return true;
+    }
+
+    if (strncmp(command, kSetFailsafePrefix, sizeof(kSetFailsafePrefix) - 1) == 0) {
+        uint32_t duty_percent = 0;
+        if (!parseExactUnsigned(command + sizeof(kSetFailsafePrefix) - 1, &duty_percent)
+            || duty_percent > UINT8_MAX) {
+            writeError(writer, "set-failsafe", "invalid-value");
+            return true;
+        }
+
+        module_fan::PolicyState state;
+        module_fan::getPolicyState(&state);
+        state.config.sensor_failsafe_duty_percent = static_cast<uint8_t>(duty_percent);
+        const esp_err_t result = module_fan::setPolicyConfig(state.config);
+        if (result != ESP_OK) {
+            writeEspError(writer, "set-failsafe", result);
+        } else {
+            writePolicyState(writer, "set-failsafe");
+        }
+        return true;
+    }
+
+    if (strcmp(command, "module-fan-policy=save") == 0) {
+        const esp_err_t result = module_fan::savePolicyConfig();
+        if (result != ESP_OK) {
+            writeEspError(writer, "save", result);
+        } else {
+            writePolicyState(writer, "save");
+        }
+        return true;
+    }
+
+    if (strcmp(command, "module-fan-policy=load") == 0) {
+        const esp_err_t result = module_fan::loadPolicyConfig();
+        if (result != ESP_OK) {
+            writeEspError(writer, "load", result);
+        } else {
+            writePolicyState(writer, "load");
+        }
+        return true;
+    }
+
+    if (strcmp(command, "module-fan-policy=defaults") == 0) {
+        module_fan::restoreDefaultPolicy();
+        writePolicyState(writer, "defaults");
+        return true;
+    }
+
+    return false;
+}
+
+} // namespace module_fan_policy_commands
+} // namespace debug
