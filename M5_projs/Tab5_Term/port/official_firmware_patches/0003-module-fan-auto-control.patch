new file mode 100644
index 0000000000000000000000000000000000000000..c77d677824aecca2616ad727e3956b0a311a4e85
--- /dev/null
+++ b/platforms/tab5/main/hal/components/module_fan/module_fan_policy.cpp
@@ -0,0 +1,123 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Tab5 terminal port contributors
+ *
+ * SPDX-License-Identifier: MIT
+ */
+#include "module_fan_policy.h"
+
+namespace module_fan {
+namespace {
+
+constexpr uint32_t kMinimumControlIntervalMs = 1000;
+constexpr uint32_t kMaximumControlIntervalMs = 60000;
+constexpr int16_t kMinimumPolicyTemperatureDeciCelsius = 0;
+constexpr int16_t kMaximumPolicyTemperatureDeciCelsius = 1000;
+
+} // namespace
+
+PolicyConfig defaultPolicyConfig()
+{
+    PolicyConfig config;
+    config.interval_ms = kDefaultControlIntervalMs;
+    config.sensor_failsafe_duty_percent = 50;
+    config.levels[0] = {400, 350, 29};
+    config.levels[1] = {500, 450, 49};
+    config.levels[2] = {600, 550, 69};
+    config.levels[3] = {650, 600, 98};
+    return config;
+}
+
+bool validatePolicyConfig(const PolicyConfig& config)
+{
+    if (config.interval_ms < kMinimumControlIntervalMs || config.interval_ms > kMaximumControlIntervalMs
+        || config.sensor_failsafe_duty_percent > 100) {
+        return false;
+    }
+
+    for (size_t index = 0; index < kPolicyLevelCount; ++index) {
+        const PolicyLevel& level = config.levels[index];
+        if (level.enter_deci_celsius < kMinimumPolicyTemperatureDeciCelsius
+            || level.enter_deci_celsius > kMaximumPolicyTemperatureDeciCelsius
+            || level.exit_deci_celsius < kMinimumPolicyTemperatureDeciCelsius
+            || level.exit_deci_celsius > kMaximumPolicyTemperatureDeciCelsius
+            || level.exit_deci_celsius > level.enter_deci_celsius || level.duty_percent == 0
+            || level.duty_percent > 100) {
+            return false;
+        }
+
+        if (index > 0) {
+            const PolicyLevel& previous = config.levels[index - 1];
+            if (level.enter_deci_celsius <= previous.enter_deci_celsius
+                || level.exit_deci_celsius <= previous.exit_deci_celsius
+                || level.duty_percent < previous.duty_percent) {
+                return false;
+            }
+        }
+    }
+
+    return true;
+}
+
+bool policyConfigsEqual(const PolicyConfig& left, const PolicyConfig& right)
+{
+    if (left.interval_ms != right.interval_ms
+        || left.sensor_failsafe_duty_percent != right.sensor_failsafe_duty_percent) {
+        return false;
+    }
+
+    for (size_t index = 0; index < kPolicyLevelCount; ++index) {
+        const PolicyLevel& left_level = left.levels[index];
+        const PolicyLevel& right_level = right.levels[index];
+        if (left_level.enter_deci_celsius != right_level.enter_deci_celsius
+            || left_level.exit_deci_celsius != right_level.exit_deci_celsius
+            || left_level.duty_percent != right_level.duty_percent) {
+            return false;
+        }
+    }
+    return true;
+}
+
+AutomaticPolicy::AutomaticPolicy()
+    : _config(defaultPolicyConfig())
+{
+}
+
+bool AutomaticPolicy::setConfig(const PolicyConfig& config)
+{
+    if (!validatePolicyConfig(config)) {
+        return false;
+    }
+
+    _config = config;
+    reset();
+    return true;
+}
+
+void AutomaticPolicy::reset()
+{
+    _cooling_level = 0;
+}
+
+PolicyDemand AutomaticPolicy::update(bool temperature_valid, float temperature_celsius)
+{
+    if (!temperature_valid) {
+        return {_cooling_level, _config.sensor_failsafe_duty_percent};
+    }
+
+    const float temperature_deci_celsius = temperature_celsius * 10.0f;
+    while (_cooling_level < kPolicyLevelCount
+           && temperature_deci_celsius >= _config.levels[_cooling_level].enter_deci_celsius) {
+        ++_cooling_level;
+    }
+    while (_cooling_level > 0
+           && temperature_deci_celsius < _config.levels[_cooling_level - 1].exit_deci_celsius) {
+        --_cooling_level;
+    }
+
+    if (_cooling_level == 0) {
+        return {0, 0};
+    }
+    return {_cooling_level, _config.levels[_cooling_level - 1].duty_percent};
+}
+
+} // namespace module_fan
