@@ -0,0 +1,119 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Tab5 terminal port contributors
+ *
+ * SPDX-License-Identifier: MIT
+ */
+#include "module_fan_telemetry.h"
+
+#include <cstdint>
+#include <cstdio>
+#include <cstring>
+
+#include <hal/components/module_fan/module_fan_service.h>
+
+namespace debug {
+namespace module_fan_telemetry {
+namespace {
+
+bool g_enabled = false;
+uint32_t g_last_sequence = 0;
+
+void emitSnapshot(LineWriter writer, bool force)
+{
+    if (!g_enabled || writer == nullptr) {
+        return;
+    }
+
+    module_fan::Snapshot snapshot;
+    if (!module_fan::getSnapshot(&snapshot)) {
+        return;
+    }
+    if (!force && snapshot.sequence == g_last_sequence) {
+        return;
+    }
+
+    char line[256];
+    snprintf(line,
+             sizeof(line),
+             "TAB5FAN SAMPLE seq=%lu uptime_ms=%llu temp_c=%.1f temp_valid=%u attached=%u comm_ok=%u "
+             "level=%u target_pct=%u applied_pct=%u rpm=%u fw=0x%02X misses=%u policy_rev=%lu",
+             static_cast<unsigned long>(snapshot.sequence),
+             static_cast<unsigned long long>(snapshot.uptime_ms),
+             static_cast<double>(snapshot.temperature_celsius),
+             snapshot.temperature_valid ? 1u : 0u,
+             snapshot.attached ? 1u : 0u,
+             snapshot.communication_ok ? 1u : 0u,
+             static_cast<unsigned>(snapshot.cooling_level),
+             static_cast<unsigned>(snapshot.target_duty_percent),
+             static_cast<unsigned>(snapshot.applied_duty_percent),
+             static_cast<unsigned>(snapshot.rpm),
+             static_cast<unsigned>(snapshot.firmware_version),
+             static_cast<unsigned>(snapshot.missed_polls),
+             static_cast<unsigned long>(snapshot.policy_revision));
+    if (writer(line)) {
+        g_last_sequence = snapshot.sequence;
+    }
+}
+
+void writeLogState(LineWriter writer)
+{
+    if (writer == nullptr) {
+        return;
+    }
+
+    module_fan::PolicyState state;
+    module_fan::getPolicyState(&state);
+
+    char line[96];
+    snprintf(line,
+             sizeof(line),
+             "TAB5FAN LOG enabled=%u interval_ms=%lu",
+             g_enabled ? 1u : 0u,
+             static_cast<unsigned long>(state.config.interval_ms));
+    writer(line);
+}
+
+} // namespace
+
+bool handleCommand(const char* command, LineWriter writer)
+{
+    if (command == nullptr) {
+        return false;
+    }
+
+    if (strcmp(command, "module-fan-log=start") == 0) {
+        g_enabled = true;
+        writeLogState(writer);
+        emitSnapshot(writer, true);
+        return true;
+    }
+
+    if (strcmp(command, "module-fan-log=stop") == 0) {
+        g_enabled = false;
+        writeLogState(writer);
+        return true;
+    }
+
+    if (strcmp(command, "module-fan-log?") == 0) {
+        writeLogState(writer);
+        return true;
+    }
+
+    return false;
+}
+
+void emitPending(LineWriter writer, bool transport_connected)
+{
+    if (!g_enabled) {
+        return;
+    }
+    if (!transport_connected) {
+        g_enabled = false;
+        return;
+    }
+
+    emitSnapshot(writer, false);
+}
+
+} // namespace module_fan_telemetry
+} // namespace debug
