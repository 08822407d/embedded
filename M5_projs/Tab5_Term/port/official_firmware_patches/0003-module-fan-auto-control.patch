diff --git a/platforms/tab5/main/hal/components/cpu_temperature.cpp b/platforms/tab5/main/hal/components/cpu_temperature.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..0d243ce1c795b233a50857e81cb6750963b50f47
--- /dev/null
+++ b/platforms/tab5/main/hal/components/cpu_temperature.cpp
@@ -0,0 +1,59 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Tab5 terminal port contributors
+ *
+ * SPDX-License-Identifier: MIT
+ */
+#include "cpu_temperature.h"
+
+#include <mutex>
+
+#include <driver/temperature_sensor.h>
+#include <esp_err.h>
+
+namespace cpu_temperature {
+namespace {
+
+std::mutex g_sensor_mutex;
+temperature_sensor_handle_t g_sensor = nullptr;
+
+bool ensure_sensor()
+{
+    if (g_sensor != nullptr) {
+        return true;
+    }
+
+    temperature_sensor_config_t config = {};
+    config.range_min = 20;
+    config.range_max = 100;
+    config.clk_src = TEMPERATURE_SENSOR_CLK_SRC_DEFAULT;
+    if (temperature_sensor_install(&config, &g_sensor) != ESP_OK) {
+        g_sensor = nullptr;
+        return false;
+    }
+
+    if (temperature_sensor_enable(g_sensor) != ESP_OK) {
+        temperature_sensor_uninstall(g_sensor);
+        g_sensor = nullptr;
+        return false;
+    }
+
+    return true;
+}
+
+} // namespace
+
+bool read(float* celsius)
+{
+    if (celsius == nullptr) {
+        return false;
+    }
+
+    std::lock_guard<std::mutex> lock(g_sensor_mutex);
+    if (!ensure_sensor()) {
+        return false;
+    }
+
+    return temperature_sensor_get_celsius(g_sensor, celsius) == ESP_OK;
+}
+
+} // namespace cpu_temperature
