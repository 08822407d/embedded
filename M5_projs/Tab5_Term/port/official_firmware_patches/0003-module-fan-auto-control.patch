diff --git a/platforms/tab5/main/hal/components/module_fan/module_fan_config_store.cpp b/platforms/tab5/main/hal/components/module_fan/module_fan_config_store.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..74a956ca90d088e32903979a6d9a9653fce059cb
--- /dev/null
+++ b/platforms/tab5/main/hal/components/module_fan/module_fan_config_store.cpp
@@ -0,0 +1,152 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Tab5 terminal port contributors
+ *
+ * SPDX-License-Identifier: MIT
+ */
+#include "module_fan_config_store.h"
+
+#include <cstddef>
+#include <cstdint>
+
+#include <nvs.h>
+
+#include "../persistent_storage.h"
+
+namespace module_fan {
+namespace config_store {
+namespace {
+
+constexpr char kNamespace[] = "module_fan";
+constexpr char kPolicyKey[] = "policy_v1";
+constexpr uint32_t kPolicyMagic = 0x314E4146;
+constexpr uint16_t kPolicyVersion = 1;
+
+struct StoredPolicyLevel {
+    int16_t enter_deci_celsius;
+    int16_t exit_deci_celsius;
+    uint8_t duty_percent;
+    uint8_t reserved[3];
+};
+
+struct StoredPolicy {
+    uint32_t magic;
+    uint16_t version;
+    uint16_t size;
+    uint32_t interval_ms;
+    uint8_t sensor_failsafe_duty_percent;
+    uint8_t level_count;
+    uint8_t reserved[2];
+    StoredPolicyLevel levels[kPolicyLevelCount];
+};
+
+static_assert(sizeof(StoredPolicyLevel) == 8);
+static_assert(sizeof(StoredPolicy) == 48);
+
+bool decode(const StoredPolicy& stored, PolicyConfig* config)
+{
+    if (config == nullptr || stored.magic != kPolicyMagic || stored.version != kPolicyVersion
+        || stored.size != sizeof(StoredPolicy) || stored.level_count != kPolicyLevelCount) {
+        return false;
+    }
+
+    PolicyConfig candidate;
+    candidate.interval_ms = stored.interval_ms;
+    candidate.sensor_failsafe_duty_percent = stored.sensor_failsafe_duty_percent;
+    for (size_t index = 0; index < kPolicyLevelCount; ++index) {
+        candidate.levels[index].enter_deci_celsius = stored.levels[index].enter_deci_celsius;
+        candidate.levels[index].exit_deci_celsius = stored.levels[index].exit_deci_celsius;
+        candidate.levels[index].duty_percent = stored.levels[index].duty_percent;
+    }
+
+    if (!validatePolicyConfig(candidate)) {
+        return false;
+    }
+    *config = candidate;
+    return true;
+}
+
+StoredPolicy encode(const PolicyConfig& config)
+{
+    StoredPolicy stored = {};
+    stored.magic = kPolicyMagic;
+    stored.version = kPolicyVersion;
+    stored.size = sizeof(StoredPolicy);
+    stored.interval_ms = config.interval_ms;
+    stored.sensor_failsafe_duty_percent = config.sensor_failsafe_duty_percent;
+    stored.level_count = kPolicyLevelCount;
+    for (size_t index = 0; index < kPolicyLevelCount; ++index) {
+        stored.levels[index].enter_deci_celsius = config.levels[index].enter_deci_celsius;
+        stored.levels[index].exit_deci_celsius = config.levels[index].exit_deci_celsius;
+        stored.levels[index].duty_percent = config.levels[index].duty_percent;
+    }
+    return stored;
+}
+
+} // namespace
+
+esp_err_t load(PolicyConfig* config)
+{
+    if (config == nullptr) {
+        return ESP_ERR_INVALID_ARG;
+    }
+
+    esp_err_t result = persistent_storage::ensureInitialized();
+    if (result != ESP_OK) {
+        return result;
+    }
+
+    nvs_handle_t handle = 0;
+    result = nvs_open(kNamespace, NVS_READONLY, &handle);
+    if (result != ESP_OK) {
+        return result;
+    }
+
+    size_t stored_size = 0;
+    result = nvs_get_blob(handle, kPolicyKey, nullptr, &stored_size);
+    if (result == ESP_OK && stored_size != sizeof(StoredPolicy)) {
+        result = ESP_ERR_INVALID_RESPONSE;
+    }
+
+    StoredPolicy stored = {};
+    if (result == ESP_OK) {
+        result = nvs_get_blob(handle, kPolicyKey, &stored, &stored_size);
+    }
+    nvs_close(handle);
+
+    if (result != ESP_OK) {
+        return result;
+    }
+    if (!decode(stored, config)) {
+        return ESP_ERR_INVALID_RESPONSE;
+    }
+    return ESP_OK;
+}
+
+esp_err_t save(const PolicyConfig& config)
+{
+    if (!validatePolicyConfig(config)) {
+        return ESP_ERR_INVALID_ARG;
+    }
+
+    esp_err_t result = persistent_storage::ensureInitialized();
+    if (result != ESP_OK) {
+        return result;
+    }
+
+    nvs_handle_t handle = 0;
+    result = nvs_open(kNamespace, NVS_READWRITE, &handle);
+    if (result != ESP_OK) {
+        return result;
+    }
+
+    const StoredPolicy stored = encode(config);
+    result = nvs_set_blob(handle, kPolicyKey, &stored, sizeof(stored));
+    if (result == ESP_OK) {
+        result = nvs_commit(handle);
+    }
+    nvs_close(handle);
+    return result;
+}
+
+} // namespace config_store
+} // namespace module_fan
