new file mode 100644
index 0000000000000000000000000000000000000000..50431030db195cb54c302983f1100534b12280ea
--- /dev/null
+++ b/platforms/tab5/main/hal/components/module_fan/module_fan_device.cpp
@@ -0,0 +1,146 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Tab5 terminal port contributors
+ *
+ * SPDX-License-Identifier: MIT
+ */
+#include "module_fan_device.h"
+
+namespace module_fan {
+namespace {
+
+constexpr uint8_t kAddress = 0x18;
+constexpr uint32_t kI2cFrequencyHz = 400000;
+constexpr int kI2cTimeoutMs = 50;
+
+constexpr uint8_t kRegControl = 0x00;
+constexpr uint8_t kRegPwmFrequency = 0x10;
+constexpr uint8_t kRegPwmDutyCycle = 0x20;
+constexpr uint8_t kRegRpm = 0x30;
+constexpr uint8_t kRegFirmwareVersion = 0xFE;
+constexpr uint8_t kRegI2cAddress = 0xFF;
+
+constexpr uint8_t kFanDisable = 0x00;
+constexpr uint8_t kFanEnable = 0x01;
+constexpr uint8_t kPwmFrequency24KHz = 0x02;
+
+} // namespace
+
+esp_err_t Device::begin(i2c_master_bus_handle_t bus_handle)
+{
+    if (bus_handle == nullptr) {
+        return ESP_ERR_INVALID_ARG;
+    }
+    if (_bus_handle != nullptr && _bus_handle != bus_handle) {
+        return ESP_ERR_INVALID_STATE;
+    }
+
+    _bus_handle = bus_handle;
+    return ESP_OK;
+}
+
+esp_err_t Device::probe() const
+{
+    if (_bus_handle == nullptr) {
+        return ESP_ERR_INVALID_STATE;
+    }
+    return i2c_master_probe(_bus_handle, kAddress, kI2cTimeoutMs);
+}
+
+esp_err_t Device::connect()
+{
+    if (_bus_handle == nullptr) {
+        return ESP_ERR_INVALID_STATE;
+    }
+    if (_device_handle != nullptr) {
+        return ESP_OK;
+    }
+
+    i2c_device_config_t config = {};
+    config.dev_addr_length = I2C_ADDR_BIT_LEN_7;
+    config.device_address = kAddress;
+    config.scl_speed_hz = kI2cFrequencyHz;
+    return i2c_master_bus_add_device(_bus_handle, &config, &_device_handle);
+}
+
+esp_err_t Device::disconnect()
+{
+    if (_device_handle == nullptr) {
+        return ESP_OK;
+    }
+
+    const esp_err_t result = i2c_master_bus_rm_device(_device_handle);
+    if (result == ESP_OK) {
+        _device_handle = nullptr;
+    }
+    return result;
+}
+
+esp_err_t Device::readIdentity(uint8_t* firmware_version) const
+{
+    if (firmware_version == nullptr) {
+        return ESP_ERR_INVALID_ARG;
+    }
+
+    uint8_t reported_address = 0;
+    esp_err_t result = readRegister(kRegI2cAddress, &reported_address, 1);
+    if (result != ESP_OK) {
+        return result;
+    }
+    if (reported_address != kAddress) {
+        return ESP_ERR_INVALID_RESPONSE;
+    }
+
+    return readRegister(kRegFirmwareVersion, firmware_version, 1);
+}
+
+esp_err_t Device::configurePwm24KHz() const
+{
+    return writeRegister8(kRegPwmFrequency, kPwmFrequency24KHz);
+}
+
+esp_err_t Device::applyDutyPercent(uint8_t duty_percent) const
+{
+    if (duty_percent > 100) {
+        return ESP_ERR_INVALID_ARG;
+    }
+
+    esp_err_t result = writeRegister8(kRegPwmDutyCycle, duty_percent);
+    if (result != ESP_OK) {
+        return result;
+    }
+    return writeRegister8(kRegControl, duty_percent == 0 ? kFanDisable : kFanEnable);
+}
+
+esp_err_t Device::readRpm(uint16_t* rpm) const
+{
+    if (rpm == nullptr) {
+        return ESP_ERR_INVALID_ARG;
+    }
+
+    uint8_t data[2] = {};
+    const esp_err_t result = readRegister(kRegRpm, data, sizeof(data));
+    if (result == ESP_OK) {
+        *rpm = static_cast<uint16_t>(data[0]) | (static_cast<uint16_t>(data[1]) << 8);
+    }
+    return result;
+}
+
+esp_err_t Device::readRegister(uint8_t reg, uint8_t* data, size_t length) const
+{
+    if (_device_handle == nullptr || data == nullptr || length == 0) {
+        return ESP_ERR_INVALID_ARG;
+    }
+    return i2c_master_transmit_receive(_device_handle, &reg, 1, data, length, kI2cTimeoutMs);
+}
+
+esp_err_t Device::writeRegister8(uint8_t reg, uint8_t value) const
+{
+    if (_device_handle == nullptr) {
+        return ESP_ERR_INVALID_STATE;
+    }
+
+    const uint8_t data[] = {reg, value};
+    return i2c_master_transmit(_device_handle, data, sizeof(data), kI2cTimeoutMs);
+}
+
+} // namespace module_fan
