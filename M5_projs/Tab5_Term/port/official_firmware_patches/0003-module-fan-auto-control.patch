+
+#include <driver/i2c_master.h>
+#include <esp_err.h>
+
+#include "module_fan_policy.h"
+
+namespace module_fan {
+
+enum class PolicySource : uint8_t {
+    CompiledDefaults,
+    PersistedNvs,
+    Runtime,
+};
+
+struct PolicyState {
+    PolicyConfig config = defaultPolicyConfig();
+    PolicySource source = PolicySource::CompiledDefaults;
+    bool dirty = false;
