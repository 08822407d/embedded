@@ -108,6 +111,86 @@ extern SPIClass SPI;
 
 #define MAX_PKT_LENGTH 255
 
+#if C6L_USE_IO_EXPANDER
+static constexpr uint8_t C6L_IOE_ADDR = 0x43;
+static constexpr uint8_t C6L_IOE_REG_ID = 0x01;
+static constexpr uint8_t C6L_IOE_REG_DIR = 0x03;
+static constexpr uint8_t C6L_IOE_REG_OUT = 0x05;
+static constexpr uint8_t C6L_IOE_REG_HIZ = 0x07;
+static constexpr uint8_t C6L_IOE_REG_IN_DEF = 0x09;
+static constexpr uint8_t C6L_IOE_REG_PULL_EN = 0x0B;
+static constexpr uint8_t C6L_IOE_REG_PULL_SEL = 0x0D;
+static constexpr uint8_t C6L_IOE_REG_INT_MASK = 0x11;
+static constexpr uint8_t C6L_IOE_PIN_LNA_EN = 5;
+static constexpr uint8_t C6L_IOE_PIN_ANT_SW = 6;
+static constexpr uint8_t C6L_IOE_PIN_NRST = 7;
+
+static bool c6l_ioe_ready = false;
+static uint8_t c6l_ioe_out = 0b10000000;
+
+static bool c6l_ioe_write(uint8_t reg, uint8_t value) {
+  Wire.beginTransmission(C6L_IOE_ADDR);
+  Wire.write(reg);
+  Wire.write(value);
+  return Wire.endTransmission() == 0;
+}
+
+static uint8_t c6l_ioe_read(uint8_t reg) {
+  Wire.beginTransmission(C6L_IOE_ADDR);
+  Wire.write(reg);
+  if (Wire.endTransmission(false) != 0) { return 0; }
+  if (Wire.requestFrom(C6L_IOE_ADDR, (uint8_t)1) != 1) { return 0; }
+  return Wire.read();
+}
+
+static bool c6l_ioe_set(uint8_t pin, bool level) {
+  if (level) { c6l_ioe_out |= (1 << pin); }
+  else       { c6l_ioe_out &= ~(1 << pin); }
+  return c6l_ioe_write(C6L_IOE_REG_OUT, c6l_ioe_out);
+}
+
+static bool c6l_ioe_begin() {
+  if (c6l_ioe_ready) { return true; }
+
+  Wire.begin(I2C_SDA, I2C_SCL);
+  Wire.setClock(400000);
+
+  if (c6l_ioe_read(C6L_IOE_REG_ID) == 0) { return false; }
+
+  const uint8_t init_regs[][2] = {
+    {C6L_IOE_REG_DIR,      0b11100000},
+    {C6L_IOE_REG_OUT,      0b10000000},
+    {C6L_IOE_REG_HIZ,      0b00011100},
+    {C6L_IOE_REG_PULL_SEL, 0b11000011},
+    {C6L_IOE_REG_PULL_EN,  0b11000011},
+    {C6L_IOE_REG_IN_DEF,   0b00000011},
+    {C6L_IOE_REG_INT_MASK, 0b11111100},
+  };
+
+  for (size_t i = 0; i < sizeof(init_regs) / sizeof(init_regs[0]); i++) {
+    if (!c6l_ioe_write(init_regs[i][0], init_regs[i][1])) { return false; }
+  }
+
+  c6l_ioe_out = 0b10000000;
+  c6l_ioe_ready = true;
+  return true;
+}
+
+static bool c6l_radio_enable_rf_paths() {
+  return c6l_ioe_set(C6L_IOE_PIN_ANT_SW, true) &&
+         c6l_ioe_set(C6L_IOE_PIN_LNA_EN, true);
+}
+
+static bool c6l_radio_reset() {
+  if (!c6l_ioe_begin()) { return false; }
+  if (!c6l_ioe_set(C6L_IOE_PIN_NRST, false)) { return false; }
+  delay(100);
+  if (!c6l_ioe_set(C6L_IOE_PIN_NRST, true)) { return false; }
+  delay(10);
+  return c6l_radio_enable_rf_paths();
+}
+#endif
