+void c6l_autoprovision() {
+  #if HAS_EEPROM
+    bool c6l_needs_bootstrap = EEPROM.read(eeprom_addr(ADDR_INFO_LOCK)) != INFO_LOCK_BYTE;
+    bool c6l_has_early_custom_id = EEPROM.read(eeprom_addr(ADDR_PRODUCT)) == PRODUCT_M5STACK &&
+                                   EEPROM.read(eeprom_addr(ADDR_MODEL)) == MODEL_5C;
+    bool c6l_has_early_bad_date = EEPROM.read(eeprom_addr(ADDR_MADE + 0)) == 0x20 &&
+                                  EEPROM.read(eeprom_addr(ADDR_MADE + 1)) == 0x26 &&
+                                  EEPROM.read(eeprom_addr(ADDR_MADE + 2)) == 0x06 &&
+                                  EEPROM.read(eeprom_addr(ADDR_MADE + 3)) == 0x24;
+    bool c6l_has_early_bad_serial = EEPROM.read(eeprom_addr(ADDR_SERIAL + 0)) == 0x81 &&
+                                    EEPROM.read(eeprom_addr(ADDR_SERIAL + 1)) == 0xFF &&
+                                    EEPROM.read(eeprom_addr(ADDR_SERIAL + 2)) == 0xFE &&
+                                    EEPROM.read(eeprom_addr(ADDR_SERIAL + 3)) == 0x50;
+    if (!c6l_needs_bootstrap && !c6l_has_early_custom_id && !c6l_has_early_bad_date && !c6l_has_early_bad_serial) { return; }
+
+    uint8_t info[CHECKSUMMED_SIZE];
+    memset(info, 0, sizeof(info));
+
+    uint8_t mac[6] = {0};
+    esp_read_mac(mac, ESP_MAC_WIFI_STA);
+    info[ADDR_PRODUCT] = PRODUCT_RNODE;
+    info[ADDR_MODEL] = MODEL_A6;
+    info[ADDR_HW_REV] = 0x01;
+    info[ADDR_SERIAL + 0] = mac[2];
+    info[ADDR_SERIAL + 1] = mac[3];
+    info[ADDR_SERIAL + 2] = mac[4];
+    info[ADDR_SERIAL + 3] = mac[5];
+
+    const uint32_t made_ts = 1782230400UL; // 2026-06-24 00:00:00 +0800
+    info[ADDR_MADE + 0] = (made_ts >> 24) & 0xFF;
+    info[ADDR_MADE + 1] = (made_ts >> 16) & 0xFF;
+    info[ADDR_MADE + 2] = (made_ts >> 8) & 0xFF;
+    info[ADDR_MADE + 3] = made_ts & 0xFF;
+
+    for (uint8_t i = 0; i < CHECKSUMMED_SIZE; i++) {
+      eeprom_update(eeprom_addr(i), info[i]);
+    }
+
+    unsigned char *hash = MD5::make_hash((char *)info, CHECKSUMMED_SIZE);
+    for (uint8_t i = 0; i < 16; i++) {
+      eeprom_update(eeprom_addr(ADDR_CHKSUM + i), hash[i]);
+    }
+    free(hash);
+
+    eeprom_update(eeprom_addr(ADDR_CONF_OK), 0x00);
+    eeprom_update(eeprom_addr(ADDR_INFO_LOCK), INFO_LOCK_BYTE);
+  #endif
+}
